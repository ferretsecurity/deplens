{
  "root": "/path/to/sample-monorepo",
  "manifests": [
    {
      "type": "python-requirements-dir",
      "path": "apps/backend/requirements/base.txt",
      "dependencies": [
        {
          "raw": "requests==2.32.3",
          "name": "requests",
          "constraint": "==2.32.3"
        },
        {
          "raw": "pydantic==2.9.2",
          "name": "pydantic",
          "constraint": "==2.9.2"
        }
      ],
      "has_dependencies": true
    },
    {
      "type": "python-pipfile-lock",
      "path": "backend/Pipfile.lock",
      "dependencies": [
        {
          "raw": "requests==2.32.3",
          "name": "requests",
          "version": "2.32.3",
          "section": "default"
        },
        {
          "raw": "pytest==8.3.3",
          "name": "pytest",
          "version": "8.3.3",
          "section": "develop"
        }
      ],
      "has_dependencies": true
    },
    {
      "type": "python-conda-lock",
      "path": "backend/conda-lock.yml",
      "has_dependencies": false
    },
    {
      "type": "python-pdm-lock",
